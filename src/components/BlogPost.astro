---
const { title, date, link } = Astro.props;
---

<div class="relative">
  <a href={link} class="">
    <div
      class="mt-4 flex font-semibold justify-between items-center px-2 py-1 group hover:-translate-y-1 bg-neutral-950 hover:-translate-x-1 transition-all duration-200 ease-in-out"
    >
      <h3
        class="text-base mb-2 text-neutral-300 group-hover:text-neutral-200 underline underline-offset-4"
      >
        {title}
      </h3>
      <p class="text-neutral-400 text-sm tabular-nums">{date}</p>
    </div>
  </a>
  <div
    class="w-full h-full absolute top-0 left-0 bg-emerald-700 -z-10 group-hover:translate-x-1 group-hover:translate-y-1 group-hover:-z-10 transition-all"
  >
  </div>
</div>
